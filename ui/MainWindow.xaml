<Window
    x:Class="Pickles_Playlist_Editor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animation="using:Microsoft.UI.Xaml.Media.Animation"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    xmlns:local="using:Pickles_Playlist_Editor"
    Title="Pickles Playlist Editor">

    <Grid x:Name="RootGrid" RequestedTheme="Dark">

        <Grid x:Name="MainContentGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton x:Name="AddSongsButton" x:Uid="AddSongsButton" Label="Add Songs" Icon="Add" Click="AddSongsButton_Click">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="FromMyComputerMenuItem" x:Uid="FromMyComputerMenuItem" Text="From My Computer" Click="fromMyComputerToolStripMenuItem_Click"/>
                        <MenuFlyoutItem x:Name="FromYouTubeMenuItem" x:Uid="FromYouTubeMenuItem" Text="From YouTube" Click="YtDownloadButton_Click"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton x:Name="NewButton" x:Uid="NewButton" Label="New Playlist" Click="NewButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8F4;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="DeleteButton" x:Uid="DeleteButton" Label="Delete" IsEnabled="False" Click="DeleteButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74D;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="ShuffleButton" x:Uid="ShuffleButton" Label="Shuffle" IsEnabled="False" Click="ShuffleButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8B1;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="SortByBPMButton" x:Uid="SortByBPMButton" Label="Sort" IsEnabled="False">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8CB;"/></AppBarButton.Icon>
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="SortByBPMMenuItem" x:Uid="SortByBPMMenuItem" Text="Sort by BPM" Click="SortByBPM_Click"/>
                        <MenuFlyoutItem x:Name="SortByNameMenuItem" x:Uid="SortByNameMenuItem" Text="Sort by Name" Click="SortByName_Click"/>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarSeparator/>
            <AppBarButton x:Name="PreviousButton" x:Uid="PreviousButton" Label="Previous" Click="PreviousButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE892;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="PlayButton" x:Uid="PlayButton" Label="Play" Click="PlayButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE768;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="PauseButton" x:Uid="PauseButton" Label="Pause" Click="PauseButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE769;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="StopButton" x:Uid="StopButton" Label="Stop" Click="StopIcon_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE71A;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton x:Name="NextButton" x:Uid="NextButton" Label="Next" Click="NextButton_Click">
                <AppBarButton.Icon><FontIcon Glyph="&#xE893;"/></AppBarButton.Icon>
            </AppBarButton>
            <CommandBar.SecondaryCommands>
                <AppBarButton x:Name="SettingsButton" x:Uid="SettingsButton" Label="Settings" Click="SettingsButton_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE713;"/></AppBarButton.Icon>
                </AppBarButton>
                <AppBarButton x:Name="HelpButton" x:Uid="HelpButton" Label="Help" Click="HelpButton_Click">
                    <AppBarButton.Icon><FontIcon Glyph="&#xE897;"/></AppBarButton.Icon>
                </AppBarButton>
            </CommandBar.SecondaryCommands>
        </CommandBar>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="4,4,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SearchLabel" x:Uid="SearchLabel" Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="4,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged"/>
        </Grid>

        <!-- Playlist tree -->
        <Grid Grid.Row="2" Margin="4,4,4,0">
            <Grid.Background>
                <ImageBrush x:Name="TreeViewBackgroundBrush" ImageSource="picklebackground.png" Stretch="UniformToFill" Opacity="0.15"/>
            </Grid.Background>
        <TreeView
            x:Name="PlaylistTreeView"
            Margin="0"
            SelectionMode="Single"
            AllowDrop="True"
            CanDragItems="True"
            CanReorderItems="False"
            ItemsSource="{x:Bind RootPlaylistItems, Mode=OneWay}"
            DragItemsStarting="PlaylistTreeView_DragItemsStarting"
            DragItemsCompleted="PlaylistTreeView_DragItemsCompleted"
            DragOver="PlaylistTreeView_DragOver"
            Drop="PlaylistTreeView_Drop"
            Tapped="PlaylistTreeView_Tapped"
            DoubleTapped="PlaylistTreeView_DoubleTapped"
            RightTapped="PlaylistTreeView_RightTapped"
            SelectionChanged="PlaylistTreeView_SelectionChanged"
            Loaded="PlaylistTreeView_Loaded"
            Expanding="PlaylistTreeView_Expanding"
            Collapsed="PlaylistTreeView_Collapsed">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="local:PlaylistNodeContent">
                    <TreeViewItem ItemsSource="{x:Bind Children}"
                                  IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                        <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"/>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
        </Grid>

        <!-- Progress bar -->
        <Grid Grid.Row="3" Margin="4,2,4,4">
            <ProgressBar x:Name="ProgressBar1" Minimum="0" Maximum="100" Value="0" Height="16"/>
            <TextBlock x:Name="ProgressLabel" Text="" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
        </Grid>

        </Grid>

        <Grid x:Name="BusyOverlay"
              Visibility="Collapsed"
              IsHitTestVisible="True"
              Background="#99000000">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="340"
                    Padding="20"
                    CornerRadius="12"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1"
                    Background="#CC1E1E1E">
                <StackPanel Spacing="16" HorizontalAlignment="Stretch">
                    <TextBlock Text="Please Wait" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>

                    <Image x:Name="BusyPickleImage" Width="80" Height="80" HorizontalAlignment="Center" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <media:RotateTransform x:Name="BusySpinnerRotate" />
                        </Image.RenderTransform>
                    </Image>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="BusyProgressLabel"
                                   Text=""
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="WrapWholeWords"/>
                        <ProgressBar x:Name="BusyProgressBar" Minimum="0" Maximum="100" Value="0" Height="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
