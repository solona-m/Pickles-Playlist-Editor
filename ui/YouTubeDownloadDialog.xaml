<ContentDialog
    x:Class="Pickles_Playlist_Editor.YouTubeDownloadDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="YouTubeDlg"
    Title="Add Songs From YouTube"
    PrimaryButtonText="Download"
    CloseButtonText="Close"
    PrimaryButtonClick="DownloadButton_Click"
    DefaultButton="Primary">

    <StackPanel Spacing="8" MinWidth="480">

        <TextBlock x:Uid="YouTubeUrlLabel" Text="YouTube URL:"/>
        <TextBox x:Name="UrlTextBox"/>

        <TextBlock x:Uid="ModeLabel" Text="Mode:"/>
        <ComboBox x:Name="ModeComboBox" SelectedIndex="0" HorizontalAlignment="Stretch">
            <ComboBoxItem x:Uid="SingleTrackItem" Content="Single Track"/>
            <ComboBoxItem x:Uid="PlaylistItem" Content="Playlist"/>
        </ComboBox>

        <ProgressBar x:Name="ProgressBar1" Minimum="0" Maximum="100" Value="0" Height="16" Margin="0,8,0,0"/>
        <TextBlock x:Name="StatusLabel" Text="" TextWrapping="Wrap"/>

    </StackPanel>
</ContentDialog>
